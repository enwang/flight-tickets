# --- Flight tracker config ---

# Optional United account identifier. The tracker uses a persistent local
# browser profile, so the preferred login flow is:
# .venv/bin/python scripts/setup_united_browser_login.py
UA_ACCOUNT=

# Optional email recipients (comma/semicolon/space separated)
# Example: REPORT_EMAIL=me@example.com,partner@example.com
REPORT_EMAIL=

# Optional SMS recipients (E.164 format, comma/semicolon/space separated)
# Example: SMS_TO=+14155550123,+14155550124
SMS_TO=

# Recommended: Twilio SMS config
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# Optional SMTP delivery (email)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_TLS=true
SMTP_SSL=false

# Optional: sender label for subject context (currently informational)
REPORT_NAME=Flight Tracker
